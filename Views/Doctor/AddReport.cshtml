@{
}


@model ReportVM
@{
    ViewData["Title"] = "Add Report";
}

<div class="d-flex align-items-center mb-3">
    <i class="bi bi-file-earmark-medical-fill text-primary fs-3 me-2"></i>
    <h4 class="fw-bold mb-0">Add Medical Report</h4>
</div>

<div class="row">
    <div class="col-md-7">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-success text-white">
                <i class="bi bi-file-earmark-plus me-1"></i>Report Details
            </div>
            <div class="card-body p-4">

                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert alert-danger py-2">
                        <div asp-validation-summary="All" class="mb-0"></div>
                    </div>
                }

                <div class="alert alert-info small py-2 mb-3">
                    Appointment ID: <code>@Model.AppointmentId</code>
                </div>

                <form asp-action="AddReport" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="AppointmentId" />

                    <div class="mb-3">
                        <label asp-for="Title" class="form-label fw-semibold">
                            Title <span class="text-danger">*</span>
                        </label>
                        <input asp-for="Title" class="form-control"
                               placeholder="e.g. Blood Test Report" />
                        <span asp-validation-for="Title" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Content" class="form-label fw-semibold">
                            Findings / Content <span class="text-danger">*</span>
                        </label>
                        <textarea asp-for="Content" class="form-control" rows="5"
                                  placeholder="Describe the findings..."></textarea>
                        <span asp-validation-for="Content" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Remarks" class="form-label fw-semibold">
                            Remarks <small class="text-muted">(optional)</small>
                        </label>
                        <textarea asp-for="Remarks" class="form-control" rows="2"
                                  placeholder="Any extra remarks..."></textarea>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-success">
                            <i class="bi bi-save me-1"></i>Save Report
                        </button>
                        <a href="/Doctor/Queue" class="btn btn-outline-secondary">
                            <i class="bi bi-arrow-left me-1"></i>Back
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>