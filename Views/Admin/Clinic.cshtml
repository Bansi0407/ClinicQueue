@{
}


@model ClinicQueue.Models.Clinic?
@{
    ViewData["Title"] = "Clinic Info";
}

<div class="d-flex align-items-center mb-3">
    <i class="bi bi-building-fill text-primary fs-3 me-2"></i>
    <h4 class="fw-bold mb-0">Clinic Information</h4>
</div>

@if (ViewBag.Error != null)
{
    <div class="alert alert-danger">@ViewBag.Error</div>
}

@if (Model == null)
{
    <div class="alert alert-warning">No clinic data found.</div>
}
else
{
    <div class="row">
        <div class="col-md-6">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-primary text-white">
                    <i class="bi bi-info-circle me-1"></i>Details
                </div>
                <div class="card-body">
                    <table class="table table-borderless mb-0">
                        <tr>
                            <th class="text-muted w-35">Name</th>
                            <td class="fw-semibold">@(Model.Name ?? "—")</td>
                        </tr>
                        <tr>
                            <th class="text-muted">Address</th>
                            <td>@(Model.Address ?? "—")</td>
                        </tr>
                        <tr>
                            <th class="text-muted">Phone</th>
                            <td>@(Model.Phone ?? "—")</td>
                        </tr>
                        <tr>
                            <th class="text-muted">Email</th>
                            <td>@(Model.Email ?? "—")</td>
                        </tr>
                        <tr>
                            <th class="text-muted">Description</th>
                            <td>@(Model.Description ?? "—")</td>
                        </tr>
                    </table>
                </div>
            </div>
        </div>
    </div>
}