@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
}


@{
    ViewData["Title"] = "Dashboard";
    var role = ViewBag.UserRole as string ?? "";
    var userName = ViewBag.UserName as string ?? "User";
    var clinic = ViewBag.ClinicName as string ?? "Clinic";
}

<div class="p-4 mb-4 rounded-3 text-white"
     style="background: linear-gradient(135deg, #0d6efd, #0a58ca);">
    <div class="row align-items-center">
        <div class="col">
            <h4 class="fw-bold mb-1">
                <i class="bi bi-hand-wave me-2"></i>Welcome, @userName!
            </h4>
            <p class="mb-0 opacity-75">
                <i class="bi bi-building me-1"></i>@clinic
                &nbsp;&nbsp;
                <span class="badge bg-warning text-dark text-capitalize">@role</span>
            </p>
        </div>
        <div class="col-auto d-none d-md-block">
            <i class="bi bi-hospital-fill opacity-25" style="font-size:4rem"></i>
        </div>
    </div>
</div>

@* admin cards *@
@if (role.ToLower() == "admin")
{
    <div class="row g-3">
        <div class="col-md-4">
            <a href="/Admin/Users" class="text-decoration-none">
                <div class="card h-100 border-0 shadow-sm dash-card">
                    <div class="card-body d-flex align-items-center gap-3">
                        <div class="icon-box bg-primary text-white">
                            <i class="bi bi-people-fill fs-4"></i>
                        </div>
                        <div>
                            <div class="fw-semibold">Manage Users</div>
                            <small class="text-muted">View and create users</small>
                        </div>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-md-4">
            <a href="/Admin/CreateUser" class="text-decoration-none">
                <div class="card h-100 border-0 shadow-sm dash-card">
                    <div class="card-body d-flex align-items-center gap-3">
                        <div class="icon-box bg-success text-white">
                            <i class="bi bi-person-plus-fill fs-4"></i>
                        </div>
                        <div>
                            <div class="fw-semibold">Create User</div>
                            <small class="text-muted">Add new staff or patient</small>
                        </div>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-md-4">
            <a href="/Admin/Clinic" class="text-decoration-none">
                <div class="card h-100 border-0 shadow-sm dash-card">
                    <div class="card-body d-flex align-items-center gap-3">
                        <div class="icon-box bg-info text-white">
                            <i class="bi bi-building-fill fs-4"></i>
                        </div>
                        <div>
                            <div class="fw-semibold">Clinic Info</div>
                            <small class="text-muted">View clinic details</small>
                        </div>
                    </div>
                </div>
            </a>
        </div>
    </div>
}

@* patient cards *@
@if (role.ToLower() == "patient")
{
    <div class="row g-3">
        <div class="col-md-3">
            <a href="/Patient/BookAppointment" class="text-decoration-none">
                <div class="card h-100 border-0 shadow-sm dash-card">
                    <div class="card-body d-flex align-items-center gap-3">
                        <div class="icon-box bg-primary text-white">
                            <i class="bi bi-calendar-plus-fill fs-4"></i>
                        </div>
                        <div>
                            <div class="fw-semibold">Book Appointment</div>
                            <small class="text-muted">Schedule a visit</small>
                        </div>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-md-3">
            <a href="/Patient/MyAppointments" class="text-decoration-none">
                <div class="card h-100 border-0 shadow-sm dash-card">
                    <div class="card-body d-flex align-items-center gap-3">
                        <div class="icon-box bg-success text-white">
                            <i class="bi bi-calendar-check-fill fs-4"></i>
                        </div>
                        <div>
                            <div class="fw-semibold">My Appointments</div>
                            <small class="text-muted">View all bookings</small>
                        </div>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-md-3">
            <a href="/Patient/Prescriptions" class="text-decoration-none">
                <div class="card h-100 border-0 shadow-sm dash-card">
                    <div class="card-body d-flex align-items-center gap-3">
                        <div class="icon-box bg-warning text-white">
                            <i class="bi bi-capsule-pill fs-4"></i>
                        </div>
                        <div>
                            <div class="fw-semibold">Prescriptions</div>
                            <small class="text-muted">My medicines</small>
                        </div>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-md-3">
            <a href="/Patient/Reports" class="text-decoration-none">
                <div class="card h-100 border-0 shadow-sm dash-card">
                    <div class="card-body d-flex align-items-center gap-3">
                        <div class="icon-box bg-danger text-white">
                            <i class="bi bi-file-medical-fill fs-4"></i>
                        </div>
                        <div>
                            <div class="fw-semibold">Reports</div>
                            <small class="text-muted">Medical reports</small>
                        </div>
                    </div>
                </div>
            </a>
        </div>
    </div>
}

@* doctor cards *@
@if (role.ToLower() == "doctor")
{
    <div class="row g-3">
        <div class="col-md-4">
            <a href="/Doctor/Queue" class="text-decoration-none">
                <div class="card h-100 border-0 shadow-sm dash-card">
                    <div class="card-body d-flex align-items-center gap-3">
                        <div class="icon-box bg-primary text-white">
                            <i class="bi bi-list-ol fs-4"></i>
                        </div>
                        <div>
                            <div class="fw-semibold">Today's Queue</div>
                            <small class="text-muted">View waiting patients</small>
                        </div>
                    </div>
                </div>
            </a>
        </div>
    </div>
}

@* receptionist cards *@
@if (role.ToLower() == "receptionist")
{
    <div class="row g-3">
        <div class="col-md-4">
            <a href="/Receptionist/DailyQueue" class="text-decoration-none">
                <div class="card h-100 border-0 shadow-sm dash-card">
                    <div class="card-body d-flex align-items-center gap-3">
                        <div class="icon-box bg-primary text-white">
                            <i class="bi bi-clipboard-pulse-fill fs-4"></i>
                        </div>
                        <div>
                            <div class="fw-semibold">Daily Queue</div>
                            <small class="text-muted">Manage today's patients</small>
                        </div>
                    </div>
                </div>
            </a>
        </div>
    </div>
}

<p class="text-muted small mt-4">
    <i class="bi bi-calendar3 me-1"></i>Today: @DateTime.Now.ToString("dddd, dd MMMM yyyy")
</p>