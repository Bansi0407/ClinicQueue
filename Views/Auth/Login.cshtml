@{
}


@model LoginVM
@{
    ViewData["Title"] = "Login";
    Layout = "_Layout";
}

<div class="row justify-content-center mt-5">
    <div class="col-sm-10 col-md-6 col-lg-4">

        <div class="text-center mb-4">
            <i class="bi bi-hospital-fill text-primary" style="font-size:3rem"></i>
            <h3 class="fw-bold mt-2">ClinicQueue</h3>
            <p class="text-muted small">Clinic Queue Management System</p>
        </div>

        <div class="card shadow border-0">
            <div class="card-header bg-primary text-white text-center py-3">
                <h5 class="mb-0"><i class="bi bi-box-arrow-in-right me-2"></i>Sign In</h5>
            </div>
            <div class="card-body p-4">

                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert alert-danger py-2">
                        <div asp-validation-summary="All" class="mb-0"></div>
                    </div>
                }

                <form asp-action="Login" method="post">
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label asp-for="Email" class="form-label fw-semibold">Email</label>
                        <input asp-for="Email" class="form-control"
                               placeholder="email@example.com" autocomplete="username" />
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Password" class="form-label fw-semibold">Password</label>
                        <div class="input-group">
                            <input asp-for="Password" id="pwd" class="form-control"
                                   placeholder="••••••••" autocomplete="current-password" />
                            <button type="button" class="btn btn-outline-secondary"
                                    onclick="togglePwd()">
                                <i class="bi bi-eye" id="eye-icon"></i>
                            </button>
                        </div>
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>

                    <div class="d-grid">
                        <button type="submit" class="btn btn-primary btn-lg">
                            <i class="bi bi-box-arrow-in-right me-2"></i>Login
                        </button>
                    </div>
                </form>

                <div class="mt-3 p-2 bg-light rounded border small text-muted">
                    <strong>Test Login:</strong><br />
                    Email: <code>enrollment@darshan.ac.in</code><br />
                    Password: <code>password123</code>
                </div>
            </div>
        </div>

    </div>
</div>

@section Scripts {
    <script>
        function togglePwd() {
            var input = document.getElementById('pwd');
            var icon  = document.getElementById('eye-icon');
            if (input.type === 'password') {
                input.type = 'text';
                icon.className = 'bi bi-eye-slash';
            } else {
                input.type = 'password';
                icon.className = 'bi bi-eye';
            }
        }
    </script>
}