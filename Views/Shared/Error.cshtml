@{
    ViewData["Title"] = "Error";
    Layout = "_Layout";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-5 text-center">
        <div class="card shadow-sm border-0">
            <div class="card-body py-5">
                <i class="bi bi-exclamation-octagon-fill text-warning" style="font-size:3rem"></i>
                <h3 class="mt-3">Something went wrong</h3>
                <p class="text-muted">An unexpected error occurred.</p>
                <a href="/Dashboard/Index" class="btn btn-primary mt-2">
                    <i class="bi bi-house me-1"></i>Go Home
                </a>
            </div>
        </div>
    </div>
</div>